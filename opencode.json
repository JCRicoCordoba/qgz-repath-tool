{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.key": "deny",
      "*.pem": "deny",
      ".aws/**": "deny"
    },
    "bash": "ask",
    "edit": "ask",
    "webfetch": "ask",
    "external_directory": "ask"
  },
  "snapshot": true
}
